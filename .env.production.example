# ── .env de PRODUCCIÓN ─────────────────────────────────────────────────
# Copiá a `.env` en el VPS y completá. NUNCA lo subas al repo.
#   cp .env.production.example .env

# App
KORE_ENV=production
KORE_DEBUG=false
KORE_SECRET_KEY=GENERA_UNA_CLAVE_FUERTE_DE_32+_CHARS   # ej: openssl rand -hex 32
KORE_API_V1_PREFIX=/api/v1
# URL pública del backend (la que pusiste en Caddy). Evolution la usa para el webhook.
PUBLIC_BASE_URL=https://api.tudominio.com

# Datastores (apuntan a los servicios internos del compose; NO cambiar)
KORE_POSTGRES_DSN=postgresql+asyncpg://kore:kore@db:5432/kore
KORE_REDIS_URL=redis://redis:6379/0

# LLM — OpenAI (tu key real)
KORE_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
KORE_OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=

# WhatsApp — Evolution (el backend la alcanza por la red interna de Docker)
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=PONÉ_UNA_CLAVE_ADMIN_FUERTE      # la misma la usa el servicio evolution
EVOLUTION_INSTANCE=Fausto
EVOLUTION_WEBHOOK_TOKEN=PONÉ_UN_TOKEN_PARA_EL_WEBHOOK   # seguridad del webhook entrante

# Stripe (si vas a cobrar)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Concurrencia (opcional)
WEB_CONCURRENCY=4
DRAMATIQ_PROCESSES=2
DRAMATIQ_THREADS=8

# NOTA: SMTP, Google Calendar, ElevenLabs y la persona del agente ya NO van acá:
# cada cliente los carga por-tenant desde el dashboard (Integraciones).
